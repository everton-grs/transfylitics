# --- Funções Utilitárias ---

def poly2str_custom(coeffs, var='s'):
    """ Converte um vetor de coeficientes de polinômio em uma string formatada. """
    if not hasattr(coeffs, '__iter__'): return "0"
    coeffs = [c for c in coeffs if abs(c) > 1e-12]
    if not coeffs: return "0"

    s = symbols(var)
    poly = Poly(coeffs, s)
    return str(poly.as_expr()).replace('**', '^')


def parse_vector(txt, field_name):
    """ Converte uma string em um array numpy de números complexos. """
    if not txt.strip(): return np.array([])
    try:
        txt = txt.replace('[', '').replace(']', '').replace(',', ' ')
        return np.array([complex(v) for v in txt.split()], dtype=np.complex128)
    except (ValueError, TypeError):
        raise ValueError(f"Entrada inválida em '{field_name}'. Use formato MATLAB, ex: [1 -2+3j -2-3j]")


def strip_leading_zeros(v):
    """ Remove zeros à esquerda de um vetor de coeficientes. """
    v_arr = np.array(v)
    if np.all(np.abs(v_arr) < 1e-14): return np.array([0.0])
    idx = np.argmax(np.abs(v_arr) > 1e-14)
    return v_arr[idx:]


